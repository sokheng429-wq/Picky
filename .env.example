# Base URL of your Spring Boot backend's REST API.
# Copy this file to ".env" (and/or ".env.development" / ".env.production")
# and adjust the value for your environment.
#
# Spring Boot usually runs on port 8080 by default, and this project
# expects the API to be mounted under "/api" (e.g. a controller with
# @RequestMapping("/api/products")).
VITE_API_BASE_URL=https://pinky-backend.onrender.com/api
